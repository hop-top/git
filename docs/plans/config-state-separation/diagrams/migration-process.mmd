    SetTimestamp,ForRepos,ScanWorktrees,ConvertRepos,
    ForWorktrees,CheckType,SetBare,SetLinked,AddEntry,
    CheckHooks,ForGitHooks,CheckDir,MoveHooks,
    InstallWrappers,BackupOld,WriteNew,BackupRegistry step
    class AtomicWrite,Persist write
    class ShowSummary,ListRepos,ListWorktrees,Confirm success
